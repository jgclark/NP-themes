{
    "name": "Claude.ai JGC",
    "style": "Light",
    "COMMENT": "This is an extended and improved version of the built-in Claude.ai theme.",
    "author": {
        "name": "Jonathan Clark"
    },
    "editor": {
        "backgroundColor": "#faf9f5",
        "altBackgroundColor": "#f0ede6",
        "tintColor": "#cc7d5e",
        "tintColor2": "#E88B5C",
        "textColor": "#2C2416",
        "toolbarBackgroundColor": "#f0ede6",
        "_toolbarBackgroundColor": "#E4D9CC",
        "toolbarIconColor": "#5F4D46",
        "menuItemColor": "#5F4D46",
        "timeBlockColor": "#CC6D3D",
        "shouldOverwriteFont": false
    },
    "styles": {
        "body": {
            "_font": ".AppleSystemUIFont",
            "_size": 16,
            "font": "EBGaramond-Regular",
            "size": 18,
            "lineSpacing": 0.9,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 4,
            "color": "#2C2416"
        },
        "tabbed": {
            "COMMENT": "for anything indented",
            "headIndent": 36,
            "paragraphSpacing": 4
        },
        "title-mark1": {
            "color": "#452C2416",
            "size": 28,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 6
        },
        "title-mark2": {
            "color": "#452C2416",
            "size": 24,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 4
        },
        "title-mark3": {
            "color": "#452C2416",
            "size": 20,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 4
        },
        "title-mark4": {
            "color": "#452C2416",
            "size": 18,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 4
        },
        "title1": {
            "font": "EBGaramondRoman-SemiBold",
            "_color": "#141413",
            "color": "#A26803",
            "size": 28
        },
        "title2": {
            "font": "EBGaramondRoman-SemiBold",
            "_color": "#604f3c",
            "color": "#895803",
            "_backgroundColor": "#90EEE7D9",
            "_isFullWidthBorder": true,
            "_borderRadius": 8,
            "_leftBorderPadding": 6,
            "size": 24
        },
        "title3": {
            "font": "EBGaramondRoman-SemiBold",
            "color": "#895803",
            "_backgroundColor": "#90EEE7D9",
            "_isFullWidthBorder": true,
            "_leftBorderPadding": 6,
            "_borderRadius": 8,
            "size": 21
        },
        "title4": {
            "font": "EBGaramondRoman-SemiBold",
            "color": "#604f3c",
            "size": 19,
            "comment": "This is optically closer to 17pt body text.",
            "_underlineStyle": 1
        },
        "bold": {
            "font": "EBGaramondRoman-Bold",
            "_font": ".AppleSystemUIFontDemi"
        },
        "bold-left-mark": {
            "color": "#452C2416"
        },
        "bold-right-mark": {
            "color": "#452C2416"
        },
        "italic": {
            "font": "EBGaramond-Italic",
            "_font": ".AppleSystemUIFontItalic"
        },
        "italic-left-mark": {
            "color": "#452C2416"
        },
        "italic-right-mark": {
            "color": "#452C2416"
        },
        "boldItalic": {
            "font": "EBGaramondItalic-SemiBold",
            "_font": ".AppleSystemUIFontDemiItalic"
        },
        "boldItalic-left-mark": {
            "color": "#452C2416"
        },
        "boldItalic-right-mark": {
            "color": "#452C2416"
        },
        "code": {
            "font": "Menlo-Regular",
            "color": "#897348",
            "size": 15
        },
        "code-left-backtick": {
            "color": "#A0897348"
        },
        "code-right-backtick": {
            "color": "#A0897348"
        },
        "working-on": {
            "backgroundColor": "#35C5DA29",
            "lineSpacing": 0.9,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 4
        },
        "flagged-1": {
            "backgroundColor": "#F0E9DB",
            "lineSpacing": 0.9,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 4
        },
        "flagged-2": {
            "backgroundColor": "#EAE1CC",
            "lineSpacing": 0.9,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 4
        },
        "flagged-3": {
            "backgroundColor": "#E4D8BB",
            "lineSpacing": 0.9,
            "paragraphSpacingBefore": 0,
            "paragraphSpacing": 4
        },
        "todo": {
            "color": "#CC6D3D",
            "headIndent": 36,
            "lineSpacing": 0.90,
            "paragraphSpacing": 4,
            "size": 16
        },
        "checked-todo-characters": {
            "font": "noteplanstate",
            "headIndent": 36,
            "lineSpacing": 0.90,
            "paragraphSpacing": 4
        },
        "checked": {
            "headIndent": 36,
            "color": "#662C2416",
            "lineSpacing": 0.90,
            "paragraphSpacing": 4
        },
        "checked-canceled": {
            "regex": "(^\\h*[\\*\\-\\+]{1} |^\\h*[0-9]+[\\.\\)] )(\\[\\-\\] )(.*)",
            "matchPosition": 0,
            "color": "#662C2416",
            "lineSpacing": 0.90,
            "paragraphSpacing": 4,
            "strikethroughStyle": 1
        },
        "checked-scheduled": {
            "regex": "(^\\h*[\\*\\-\\+]{1} |^\\h*[0-9]+[\\.\\)] )(\\[\\>\\] )(.*)",
            "matchPosition": 0,
            "color": "#662C2416",
            "lineSpacing": 0.90,
            "paragraphSpacing": 4
        },
        "quote-mark": {
            "color": "#80E88B5C",
            "headIndent": 33,
            "size": 16
        },
        "quote-content": {
            "color": "#2C2416",
            "type": "italic",
            "headIndent": 33
        },
        "markdown-link": {
            "color": "#C89240"
        },
        "markdown-link-url": {
            "color": "#465E68"
        },
        "done-date": {
            "color": "#AAA",
            "backgroundColor": "#faf9f5",
            "size": 14
        },
        "note-title-link": {
            "color": "#662C2416"
        },
        "NoteLinks-main": {
            "regex": "(?:^|\\h)(\\[\\[)(.*?)(\\]\\])",
            "matchPosition": 8,
            "color": "#662C2416"
        },
        "NoteLinks-left-brackets": {
            "regex": "(?:^|\\h)(\\[\\[)(.*?)(\\]\\])",
            "matchPosition": 1,
            "color": "#C5487A",
            "isMarkdownCharacter": true,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true
        },
        "NoteLinks-right-brackets": {
            "regex": "(?:^|\\h)(\\[\\[)(.*?)(\\]\\])",
            "matchPosition": 3,
            "color": "#C5487A",
            "isMarkdownCharacter": true,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true
        },
        "hashtag": {
            "backgroundColor": "#f0ede6",
            "type": ""
        },
        "attag": {
            "backgroundColor": "#f0ede6",
            "type": ""
        },
        "phonenumber": {
            "color": "#897348"
        },
        "field-key": {
            "COMMENT": "Simplified form of YAML field identification, limited to 25 chars in field name at start of line",
            "regex": "^([^\\h#:\\-\\+\\*][\\s\\w]{3,26})(:\\h+)(?=[\\w\\d@!#]+)",
            "matchPosition": 1,
            "color": "#897348"
        },
        "highlighted": {
            "backgroundColor": "#F8F3B0"
        },
        "highlighted-left-marker": {
            "color": "#40000000",
            "isMarkdownCharacter": true,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true
        },
        "highlighted-right-marker": {
            "color": "#40000000",
            "isMarkdownCharacter": true,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true
        },
        "callback-button": {
            "comment": "Just for pseudo-buttons. FIXME: Ideal version not working, despite lots of attemps. So requires =b= markers around text.",
            "__regex": "\\[[^]]*?\\]\\(noteplan://.*\\)",
            "regex": "(=b=)(.*?)(=b=)",
            "matchPosition": 2,
            "backgroundColor": "#50E87B5C",
            "borderRadius": 6,
            "inlineBorder": true,
            "leftBorderPadding": 3,
            "rightBorderPadding": 3
        },
        "callback-button-left": {
            "regex": "(=b=)(.*?)(=b=)",
            "matchPosition": 1,
            "isMarkdownCharacter": true,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true,
            "color": "#44CBCCC6",
            "backgroundColor": "#E1F4FD"
        },
        "callback-button-right": {
            "regex": "(=b=)(.*?)(=b=)",
            "matchPosition": 3,
            "isMarkdownCharacter": true,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true,
            "color": "#44CBCCC6",
            "backgroundColor": "#E1F4FD"
        },
        "URL-link": {
            "regex": "\\[[^]]*?\\]\\(.*?\\)",
            "isRevealOnCursorRange": true,
            "comment": "Put cursor anywhere in markdown link and the []() syntax will be revealed. The following 4 do the hiding the rest of the time."
        },
        "URL-link-left-square-bracket": {
            "COMMENT": "Slightly more complex than the others to avoid problem with start-of-line task markers",
            "regex": "(\\[)([^]]*?)(\\])(\\()(.*?)(\\))",
            "matchPosition": 1,
            "isHiddenWithoutCursor": true,
            "isMarkdownCharacter": true
        },
        "URL-link-right-square-bracket": {
            "regex": "(\\[)(.*?)(\\])(\\()(.*?)(\\))",
            "matchPosition": 3,
            "isHiddenWithoutCursor": true,
            "isMarkdownCharacter": true
        },
        "URL-link-left-bracket": {
            "regex": "(\\[)(.*?)(\\])(\\()(.*?)(\\))",
            "matchPosition": 4,
            "isHiddenWithoutCursor": true,
            "isMarkdownCharacter": true
        },
        "URL-link-right-bracket": {
            "regex": "(\\[)(.*?)(\\])(\\()(.*?)(\\))",
            "matchPosition": 6,
            "isHiddenWithoutCursor": true,
            "isMarkdownCharacter": true
        },
        "strikethrough": {
            "strikethroughStyle": 2,
            "isRevealOnCursorRange": true
        },
        "strikethrough-left-tilde": {
            "color": "#d9d9d9",
            "isMarkdownCharacter": true,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true
        },
        "strikethrough-right-tilde": {
            "color": "#d9d9d9",
            "isMarkdownCharacter": true,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true
        },
        "underline": {
            "underlineStyle": 1,
            "underlineColor": "#E88B5C"
        },
        "underline-left-tilde": {
            "color": "#448B7355"
        },
        "underline-right-tilde": {
            "color": "#448B7355"
        },
        "#waiting": {
            "regex": "^* (.*#waiting.*)$",
            "matchPosition": 1,
            "font": "EBGaramond-Italic"
        },
        "Templates_tags-opener": {
            "regex": "(<%[\\-=_~]?\\s+)(.*?)(\\s+[\\-]?%>)",
            "matchPosition": 1,
            "color": "#BB618e61",
            "font": "Menlo-Regular",
            "size": 15
        },
        "Templates_tags": {
            "regex": "(<%[\\-=_~]?\\s+)(.*?)(\\s+[\\-]?%>)",
            "matchPosition": 2,
            "color": "#618e61",
            "font": "Menlo-Regular",
            "size": 15
        },
        "Templates_tags-closer": {
            "regex": "(<%[\\-=_~]?\\s+)(.*?)(\\s+[\\-]?%>)",
            "matchPosition": 3,
            "color": "#BB618e61",
            "font": "Menlo-Regular",
            "size": 15
        },
        "Templates_tags-commented-out": {
            "regex": "(<%#\\-?\\s+.*?\\s+[\\-]?%>)",
            "matchPosition": 1,
            "color": "#BB618e61",
            "font": "Menlo-Regular",
            "strikethroughStyle": 1,
            "size": 15
        },
        "unfinished": {
            "regex": "\\?\\?\\?",
            "color": "#FFFFFF",
            "backgroundColor": "#FF2020"
        },
        "end-of-line-comment-hide": {
            "regex": "(.*)( // )(.*)",
            "matchPosition": 3,
            "isHiddenWithoutCursor": true,
            "color": "#BB222E33"
        },
        "end-of-line-comment-show": {
            "regex": "(.* // .*)",
            "matchPosition": 1,
            "isRevealOnCursorRange": true
        },
        "end-of-line-comment-mark": {
            "regex": "(.*)( // )",
            "matchPosition": 2,
            "isMarkdownCharacter": true,
            "color": "#99818475"
        },
        "inline-comment": {
            "regex": "(%)(%([^%]+%?)+%)(%)",
            "matchPosition": 2,
            "isRevealOnCursorRange": true,
            "isHiddenWithoutCursor": true,
            "color": "#BB222E33"
        },
        "inline-comment-mark-start": {
            "regex": "[\\s^](%%)[^\\s]",
            "matchPosition": 1,
            "isMarkdownCharacter": true,
            "color": "#99818475"
        },
        "inline-comment-mark-end": {
            "regex": "\\b(%%)[\\W^]",
            "matchPosition": 1,
            "isMarkdownCharacter": true,
            "color": "#99818475"
        },
        "verse-indicator": {
            "regex": "(§)(.*)",
            "matchPosition": 1,
            "isHiddenWithoutCursor": true,
            "isRevealOnCursorRange": true,
            "isMarkdownCharacter": true,
            "color": "#99818475"
        },
        "verse-text": {
            "regex": "(¶)(.*)",
            "matchPosition": 2,
            "color": "#F04060",
            "backgroundColor": "#f0f0f0",
            "borderRadius": 4
        }
    }
}